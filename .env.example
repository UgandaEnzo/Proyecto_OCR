# Copia este archivo como `.env` y completa los valores.
# NO subas tu `.env` real al repositorio.

# =====================
# Base de datos (PostgreSQL)
# =====================
# Opción A (recomendada): variables separadas
DB_USER=postgres
DB_PASS=UEnzo610*
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pagos_db

# Si ves errores tipo: "UnicodeDecodeError ... autentificaci\xF3n password fall\xF3",
# en algunos Windows/PostgreSQL ayuda a forzar la codificación del cliente:
# (usa UNO de los dos nombres)
# PGCLIENTENCODING=WIN1252
# DB_CLIENT_ENCODING=WIN1252

# Opción B: URL completa (si se define, tiene prioridad sobre las variables DB_*)
# DATABASE_URL=postgresql://usuario:clave@localhost:5432/pagos_db

# =====================
# Seguridad (opcional)
# =====================
# Si defines API_KEY, todas las rutas protegidas exigirán el header: x-api-key
# API_KEY=CHANGEME

# =====================
# Límites / Logging
# =====================
# Tamaño máximo de subida en MB (por defecto 10)
MAX_UPLOAD_MB=10

# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO